# ════════════════════════════════════════════════════════════════════════
# HELM .gitignore
# ════════════════════════════════════════════════════════════════════════

# ── Python ───────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyc
.pytest_cache/

# ── Secrets / logs ───────────────────────────────────────────────────────
.env
*.log

# ── Live database (real DB is data/helm.db; never track it) ──────────────
data/helm.db
data/*.db
/helm.db
*.db-shm
*.db-wal
*.db-journal

# ── Backups: plain, timestamped, editor/transfer ─────────────────────────
*.bak
*.bak.*
*.pre_*
*_bak

# ── Scratch prefixes (transfer crumbs, scratch modules) ──────────────────
_ic_*
_plc_*
_pm_*
_bps_*
_p*_*
# paper-book source modules ARE tracked source -- re-include after _p*_*:
!_paper_*.py
debit_spread_*.py
straddle_*.py

# ── HELM working-dir scripts (root-anchored; never catches the helm/ pkg) ─
/apply_*.py
/patch_*.py
/validate_*.py
/fix_*.py
/book_*.py
/helm_*.py
/helm[0-9]*.py

# ── Register / handover / scratch docs (root) ────────────────────────────
/ISSUES*bak*
/ISSUES_*_additions.md
/HELM_handover_*.md
/integrity_block.txt

# ── Generated render output / local archive ──────────────────────────────
/master.html
/master_data.json
/data/master.csv
archive/

# ── macOS ────────────────────────────────────────────────────────────────
.DS_Store

# -- s48 cleanup: bak/db-backup + one-off-script gap fix --
# Timestamped backups (patch discipline writes .bak_YYYYMMDD / .bak-YYYYMMDD):
*.bak_*
*.bak-*
data/helm.db.bak*
data/helm.db*mode=ro
# One-off scratch / migration scripts (root only; helm/ package never matched):
/migrate_*.py
/note_*.py
/checkpoint_*.py
/reconcile_*.py
/lift_*.py
/flip_*.py
/retime_*.py
/cleanup_*.py
/ws[0-9]*.py
/ws_*.py
/ib_data_probe.py
