# ── HELM working-dir artifacts ───────────────────────────────────────────
# Throwaway patch / validate / fix / booking scripts. The resolved log names
# them for the audit trail, but they're archival, not source. Root-anchored so
# nothing inside the helm/ package is ever caught.
/apply_*.py
/patch_*.py
/validate_*.py
/fix_*.py
/book_*.py
/helm_*.py
/helm[0-9]*.py

# Timestamped backups (source, schema, db, register) — anywhere in the tree
*.bak
*.bak.*

# Register / handover scratch (root)
/ISSUES*bak*
/ISSUES_*_additions.md
/HELM_handover_*.md
/integrity_block.txt

# ── SQLite runtime sidecars (never the live .db itself) ──────────────────
*.db-wal
*.db-shm
*.db-journal

# ── Python ───────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
.pytest_cache/

# ── macOS ────────────────────────────────────────────────────────────────
.DS_Store
